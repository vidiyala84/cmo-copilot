# Copy to .env and fill in for LIVE Qwen runs. Mock mode needs none of these.
# Everything ships and is tested in --mock mode; live keys are only for the
# manual submission runs.

# --- Provider --------------------------------------------------------------
# dashscope = Qwen on Alibaba Cloud Model Studio (Qwen Cloud). The only provider.
LLM_PROVIDER=dashscope

# --- DashScope / Qwen Cloud ------------------------------------------------
# Qwen models on Qwen Cloud / Alibaba Cloud Model Studio. Two front doors, same
# models:
#   - qwencloud.com                — the named sponsor; free tokens on signup.
#   - modelstudio.alibabacloud.com — the Alibaba Cloud console (deployment-proof leg).
DASHSCOPE_API_KEY=
# Endpoint: dashscope-intl compatible-mode works with a Model Studio key. If you
# register on qwencloud.com, use ITS base URL + key from that console instead.
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# MODEL IDs — optional. Left unset, config.py defaults to the qwen-plus / qwen-flash
# / qwen-max aliases on Model Studio. To pin exact versioned ids from the console,
# copy them into QWEN_ORCH_MODEL / QWEN_CHEAP_MODEL / QWEN_MAX_MODEL.
# QWEN_ORCH_MODEL=qwen-plus
# QWEN_CHEAP_MODEL=qwen-flash
# QWEN_MAX_MODEL=qwen-max

# --- Track 1 retrieval -----------------------------------------------------
# Embedding model (optional; lexical fallback used if absent or on error).
QWEN_EMBED_MODEL=text-embedding-v3

# --- Guards ----------------------------------------------------------------
# Budget guard: hard token cap per scenario run before an over_budget abort.
MAX_TOKENS_PER_RUN=60000
# Track 4 human-gate timeout in seconds (default 300; tests override to 2).
GATE_TIMEOUT_S=300
